generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum ServiceStatus {
  ACTIVE
  MAINTENANCE
  SUSPENDED
}

enum BillingStatus {
  UNPAID
  PAID
  OVERDUE
}

enum PaymentStatus {
  SUCCESS
  PENDING
  FAILED
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum ServerStatus {
  ACTIVE
  TROUBLE
  DOWN
}

model User {
  id           String         @id @default(cuid())
  customerId   String         @unique
  loginId      String         @unique
  name         String
  email        String?        @unique
  passwordHash String
  phone        String
  address      String
  serverName   String         @default("Server Jombok")
  role         Role           @default(CUSTOMER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  subscription Subscription?
  billings     Billing[]
  payments     Payment[]
  generatedAccount GeneratedAccount?
  troubleReports TroubleReport[]
}

model ServiceServer {
  id        String       @id @default(cuid())
  name      String       @unique
  status    ServerStatus @default(ACTIVE)
  note      String?
  updatedAt DateTime     @updatedAt
  createdAt DateTime     @default(now())
}

model Package {
  id           String         @id @default(cuid())
  name         String
  speedMbps    Int
  monthlyPrice Int
  description  String
  createdAt    DateTime       @default(now())
  subscriptions Subscription[]
}

model Subscription {
  id         String        @id @default(cuid())
  userId     String        @unique
  packageId  String
  status     ServiceStatus @default(ACTIVE)
  startedAt  DateTime
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  package    Package       @relation(fields: [packageId], references: [id])
}

model Billing {
  id        String        @id @default(cuid())
  userId    String
  invoiceNo String        @unique
  period    DateTime
  amount    Int
  dueDate   DateTime
  status    BillingStatus @default(UNPAID)
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@index([userId, period])
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  billingId String
  method    String
  amount    Int
  status    PaymentStatus @default(SUCCESS)
  reference String        @unique
  proofImage String?
  proofName  String?
  proofUploadedAt DateTime?
  paidAt    DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  billing   Billing       @relation(fields: [billingId], references: [id], onDelete: Cascade)

  @@index([userId, paidAt])
}

model GeneratedAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  loginId       String
  passwordPlain String
  customerName  String
  customerId    String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model TroubleReport {
  id        String       @id @default(cuid())
  userId    String
  message   String
  status    ReportStatus @default(OPEN)
  createdAt DateTime     @default(now())
  resolvedAt DateTime?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}
