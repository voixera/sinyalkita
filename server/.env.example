# Supabase Project Settings -> Database -> Connection string.
# Use the pooled connection URL for app runtime.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Use the direct connection URL for Prisma migrations.
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
JWT_SECRET="change-this-with-a-long-random-secret"
CLIENT_URL="http://localhost:3000"
PORT=4000
